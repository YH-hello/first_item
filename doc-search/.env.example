# ── Qdrant 연결 설정 ─────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=doc_search

# ── 데이터 저장 경로 ─────────────────────────────────────────────────────────
# SQLite DB 및 BM25 인덱스가 저장될 폴더 (절대경로 권장)
DATA_DIR=./data

# ── 임베딩 모델 (로컬) ───────────────────────────────────────────────────────
# 한국어/다국어 지원 모델 (첫 실행 시 자동 다운로드)
# 경량: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (278MB)
# 고성능: BAAI/bge-m3 (2.3GB) - 권장
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=cpu

# ── 텍스트 청킹 설정 ─────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── 검색 파라미터 ────────────────────────────────────────────────────────────
SEARCH_TOP_K=10
SEMANTIC_WEIGHT=0.7
KEYWORD_WEIGHT=0.3

# ── PDF 뷰어 경로 (딥링크용) ─────────────────────────────────────────────────
# Adobe Acrobat DC 기본 설치 경로
PDF_VIEWER_PATH=C:\Program Files\Adobe\Acrobat DC\Acrobat\Acrobat.exe
# SumatraPDF (무료, 경량):
# PDF_VIEWER_PATH=C:\Program Files\SumatraPDF\SumatraPDF.exe
